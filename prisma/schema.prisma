// =============================================================================
// KODY OMS — Prisma Schema
// =============================================================================
// 5 business domains: Account, Product, Order, Payment, Shipment
// + M0 membership/auth + ActionLog (tracking)
//
// Enum mapping (Frontend Korean → Prisma English):
//   OrderStatus:        주문대기→PENDING, 주문완료→CONFIRMED, 주문중지→SUSPENDED
//   ShipmentStatus:     출고대기→PENDING, 출고완료→COMPLETED
//   ShipmentItemStatus: 미출고→NOT_SHIPPED, 출고대기→PENDING, 출고완료→COMPLETED
//   ProductCategory:    앨범→ALBUM, 포토카드→PHOTOCARD, 굿즈→GOODS
//   DepositSource:      농협외환→NONGHYUP, 하나외환→HANA, Paypal→PAYPAL, Payoneer→PAYONEER
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum Currency {
  KRW
  USD
  EUR
  RUB
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SUSPENDED
}

enum ShipmentStatus {
  PENDING
  COMPLETED
}

enum ShipmentItemStatus {
  NOT_SHIPPED
  PENDING
  COMPLETED
}

enum ProductCategory {
  ALBUM
  PHOTOCARD
  GOODS
}

enum SourceSystem {
  IMWEB_KR
  SHOPIFY
  CAFE24
  MANUAL
}

enum MappingStatus {
  ACTIVE
  ORPHANED
  CONFLICTING
}

enum ProductSaleStatus {
  ON_SALE
  OFF_SALE
  SOLD_OUT
  DRAFT
}

enum ProductPriceStatus {
  CONFIRMED
  MISSING
  ZERO_NEEDS_REVIEW
  STALE_NEEDS_RECONFIRM
}

enum CategoryReviewStatus {
  PENDING
  MAPPED
  NEEDS_REVIEW
}

enum CategoryMappingSource {
  EXACT
  FALLBACK
  MANUAL
}

enum ImportBatchStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ImportRowOutcome {
  PENDING
  CREATED
  UPDATED
  UNCHANGED
  SKIPPED
  NEEDS_REVIEW
  FAILED
}

enum Incoterm {
  EXW
  FOB
  CIF
  DDP
  DAP
}

enum DepositSource {
  NONGHYUP
  HANA
  PAYPAL
  PAYONEER
}

enum PaymentType {
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
}

enum StockMovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum Role {
  ADMIN
  SALES
  OPERATIONS
  WAREHOUSE
  FINANCE
}

enum ActionType {
  INVENTORY_ADJUST
  INVENTORY_INBOUND
  ORDER_CREATE
  ORDER_CONFIRM
  ORDER_CANCEL
  SHIPMENT_PICK
  SHIPMENT_PACK
  SHIPMENT_COMPLETE
  PAYMENT_CREATE
  PAYMENT_UPDATE
  PAYMENT_DELETE
  ACCOUNT_CREATE
  ACCOUNT_UPDATE
  PRODUCT_CREATE
  PRODUCT_UPDATE
  USER_LOGIN
  USER_LOGOUT
  USER_ROLE_CHANGE
  USER_STATUS_CHANGE
}

// =============================================================================
// M0 Membership And Auth
// =============================================================================

model Employee {
  id         String         @id @default(cuid())
  name       String
  email      String         @unique
  phone      String?
  department String?
  position   String?
  status     EmployeeStatus @default(ACTIVE)
  joinedAt   DateTime?
  leftAt     DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User?
}

model User {
  id               String     @id @default(cuid())
  employeeId       String     @unique
  email            String     @unique
  loginId          String     @unique
  passwordHash     String
  displayName      String
  profileImageUrl  String?
  status           UserStatus @default(ACTIVE)
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relations
  employee            Employee             @relation(fields: [employeeId], references: [id])
  roles               UserRole[]
  inviteTokens        InviteToken[]        @relation("InvitedByUser")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  salesAccounts       Account[]            @relation("SalesRep")
  salesOrders         Order[]              @relation("OrderSalesRep")
  stockMovements      StockMovement[]
  actionLogs          ActionLog[]          @relation("ActionLogActor")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, role])
  @@index([userId])
}

model InviteToken {
  id              String    @id @default(cuid())
  email           String
  tokenHash       String    @unique
  invitedByUserId String
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  invitedBy User              @relation("InvitedByUser", fields: [invitedByUserId], references: [id])
  roles     InviteTokenRole[]

  @@index([email])
  @@index([invitedByUserId])
  @@index([expiresAt])
}

model InviteTokenRole {
  id            String   @id @default(cuid())
  inviteTokenId String
  role          Role
  createdAt     DateTime @default(now())

  inviteToken InviteToken @relation(fields: [inviteTokenId], references: [id])

  @@unique([inviteTokenId, role])
  @@index([inviteTokenId])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  deviceInfo String?
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

// =============================================================================
// Account Domain (3 models)
// =============================================================================

model Account {
  id                  String        @id @default(cuid())
  name                String
  representative      String
  primaryDepositor    String
  salesRepId          String
  defaultDiscountRate Float         @default(0)
  depositSource       DepositSource
  memo                String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  salesRep          User              @relation("SalesRep", fields: [salesRepId], references: [id])
  shippingAddresses ShippingAddress[]
  relationsAsSource AccountRelation[] @relation("AccountSource")
  relationsAsTarget AccountRelation[] @relation("AccountTarget")
  orders            Order[]
  payments          Payment[]
  shipments         Shipment[]

  @@index([salesRepId])
}

model AccountRelation {
  id               String   @id @default(cuid())
  accountId        String
  relatedAccountId String
  createdAt        DateTime @default(now())

  // Relations
  account        Account @relation("AccountSource", fields: [accountId], references: [id])
  relatedAccount Account @relation("AccountTarget", fields: [relatedAccountId], references: [id])

  @@unique([accountId, relatedAccountId])
}

model ShippingAddress {
  id              String    @id @default(cuid())
  accountId       String
  label           String
  country         String
  fullAddress     String
  isPrimary       Boolean   @default(false)
  defaultIncoterm Incoterm?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  account   Account    @relation(fields: [accountId], references: [id])
  shipments Shipment[]

  @@index([accountId])
}

// =============================================================================
// Product Domain (3 models)
// =============================================================================

model Artist {
  id          String   @id @default(cuid())
  name        String
  memberCount Int
  createdAt   DateTime @default(now())

  // Relations
  products Product[]
}

/// Product ID is KODY-owned. Existing P-ARTIST-NNN IDs are preserved; new products use KODY-PROD-NNNNNN.
model Product {
  id String @id

  artistId String?
  artist   Artist? @relation(fields: [artistId], references: [id], onDelete: Restrict)

  category              ProductCategory?
  categoryReviewStatus  CategoryReviewStatus  @default(PENDING)
  categoryMappingSource CategoryMappingSource @default(EXACT)
  sourceCategoryCodes   String[]              @default([])

  name         String
  labelName    String?
  thumbnailUrl String?

  weightG  Int?
  priceKRW Decimal @db.Decimal(15, 4)

  priceStatus           ProductPriceStatus @default(CONFIRMED)
  lastConfirmedPriceKRW Decimal?           @db.Decimal(15, 4)
  lastConfirmedPriceAt  DateTime?
  sourcePriceRaw        String?
  priceReviewNote       String?

  sku     String?
  barcode String?

  saleStatus  ProductSaleStatus @default(DRAFT)
  isDisplayed Boolean           @default(false)

  stockManaged Boolean @default(true)
  stockOnHand  Int     @default(0)

  releaseDateText String?
  releaseDate     DateTime?
  detailHtml      String?   @db.Text

  avgPurchasePriceKRW Int      @default(0)
  orderBasedStock     Int      @default(0)
  shipmentBasedStock  Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  stockMovements   StockMovement[]
  orderItems       OrderItem[]
  shipmentItems    ShipmentItem[]
  externalMappings ProductExternalMapping[]
  options          ProductOption[]

  @@index([artistId])
  @@index([category])
  @@index([categoryMappingSource])
  @@index([sku])
  @@index([barcode])
  @@index([saleStatus])
  @@index([priceStatus])
}

model ProductExternalMapping {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  sourceSystem      SourceSystem
  externalProductId String
  externalUrl       String?

  firstSeenAt     DateTime  @default(now())
  lastSyncedAt    DateTime  @default(now())
  sourceUpdatedAt DateTime?

  firstImportBatchId String?
  lastImportBatchId  String?
  lastRawHash        String?

  status MappingStatus @default(ACTIVE)

  @@unique([sourceSystem, externalProductId])
  @@index([productId])
  @@index([sourceSystem, lastSyncedAt])
}

model ProductSequence {
  key     String @id
  lastSeq Int    @default(0)
}

model ProductOption {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  name     String
  position Int    @default(0)

  values ProductOptionValue[]

  @@index([productId])
}

model ProductOptionValue {
  id String @id @default(cuid())

  optionId String
  option   ProductOption @relation(fields: [optionId], references: [id])

  value         String
  position      Int    @default(0)
  priceDeltaKRW Int    @default(0)
  stockSnapshot Int?

  @@index([optionId])
}

model ImportBatch {
  id String @id @default(cuid())

  sourceSystem   SourceSystem
  sourceFileName String?
  sourceFileHash String?

  status   ImportBatchStatus @default(PENDING)
  isDryRun Boolean           @default(true)

  totalRows       Int @default(0)
  createdRows     Int @default(0)
  updatedRows     Int @default(0)
  unchangedRows   Int @default(0)
  failedRows      Int @default(0)
  needsReviewRows Int @default(0)

  triggeredBy String?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  rows ImportRow[]

  @@index([sourceSystem, startedAt])
}

model ImportRow {
  id String @id @default(cuid())

  batchId String
  batch   ImportBatch @relation(fields: [batchId], references: [id])

  sourceSystem SourceSystem
  rowIndex     Int

  externalProductId String
  rawHash           String
  rawPayload        Json

  outcome ImportRowOutcome @default(PENDING)

  sourcePriceRaw      String?
  parsedPriceKRW      Decimal?            @db.Decimal(15, 4)
  assignedPriceStatus ProductPriceStatus?
  priceReviewReason   String?

  warnings       Json?
  warningCodes   String[] @default([])
  reviewRequired Boolean  @default(false)

  productId String?
  mappingId String?

  errorMessage String?
  createdAt    DateTime @default(now())

  @@unique([batchId, rowIndex])
  @@unique([batchId, externalProductId])
  @@index([sourceSystem, externalProductId, rawHash])
  @@index([outcome])
  @@index([warningCodes], type: Gin)
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  type        StockMovementType
  quantity    Int
  reason      String?
  createdById String?
  createdAt   DateTime          @default(now())

  // Relations
  product   Product @relation(fields: [productId], references: [id])
  createdBy User?   @relation(fields: [createdById], references: [id])

  @@index([productId])
}

// =============================================================================
// Order Domain (3 models)
// =============================================================================

/// Order ID follows business format: YYMMDDNNN0000
model Order {
  id            String      @id // Business order number: YYMMDDNNN0000
  orderDate     DateTime
  accountId     String
  salesRepId    String
  currency      Currency
  status        OrderStatus @default(PENDING)
  shippingFee   Decimal     @default(0) @db.Decimal(15, 2)
  remittanceFee Decimal     @default(0) @db.Decimal(15, 2)
  memo          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  account  Account     @relation(fields: [accountId], references: [id])
  salesRep User        @relation("OrderSalesRep", fields: [salesRepId], references: [id])
  items    OrderItem[]

  @@index([accountId])
  @@index([salesRepId])
  @@index([orderDate])
}

/// OrderItem ID follows business format: YYMMDDNNNXXXX
model OrderItem {
  id             String             @id // Business item number: YYMMDDNNNXXXX
  orderId        String
  productId      String
  unitPrice      Decimal            @db.Decimal(15, 2)
  quantity       Int
  discountRate   Decimal            @default(0) @db.Decimal(5, 4)
  subtotal       Decimal            @db.Decimal(15, 2)
  shipmentStatus ShipmentItemStatus @default(NOT_SHIPPED)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // Relations
  order         Order          @relation(fields: [orderId], references: [id])
  product       Product        @relation(fields: [productId], references: [id])
  shipmentItems ShipmentItem[]

  @@index([orderId])
  @@index([productId])
}

/// Sequence table for generating daily order numbers
model OrderSequence {
  id      Int    @id @default(autoincrement())
  date    String @unique // YYMMDD
  lastSeq Int    @default(0)
}

// =============================================================================
// Payment Domain (2 models)
// =============================================================================

model Payment {
  id            String        @id @default(cuid())
  date          DateTime
  accountId     String
  depositSource DepositSource
  currency      Currency
  amount        Decimal       @db.Decimal(15, 2)
  krwEquivalent Decimal       @db.Decimal(15, 2)
  type          PaymentType   @default(DEPOSIT)
  memo          String?
  depositorName String?
  createdAt     DateTime      @default(now())

  // Relations
  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([date])
}

model FxRate {
  id        String   @id @default(cuid())
  date      DateTime
  currency  Currency
  rateToKRW Decimal  @db.Decimal(15, 4)
  createdAt DateTime @default(now())

  @@unique([date, currency])
}

// =============================================================================
// Shipment Domain (2 models)
// =============================================================================

/// Shipment ID follows business format: SHIP-YYMMDD-NN
model Shipment {
  id                String         @id // Business ID: SHIP-YYMMDD-NN
  accountId         String
  shippingAddressId String
  shipDate          DateTime?
  incoterm          Incoterm
  undervalueFile    String?
  trackingNumber    String?
  status            ShipmentStatus @default(PENDING)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  account         Account         @relation(fields: [accountId], references: [id])
  shippingAddress ShippingAddress @relation(fields: [shippingAddressId], references: [id])
  items           ShipmentItem[]

  @@index([accountId])
  @@index([shippingAddressId])
}

model ShipmentItem {
  id          String   @id @default(cuid())
  shipmentId  String
  orderItemId String
  productId   String
  quantity    Int
  hsCode      String?
  htsCode     String?
  subtotal    Decimal  @db.Decimal(15, 2)
  createdAt   DateTime @default(now())

  // Relations
  shipment  Shipment  @relation(fields: [shipmentId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([shipmentId])
  @@index([orderItemId])
}

// =============================================================================
// ActionLog
// =============================================================================

model ActionLog {
  id           String     @id @default(cuid())
  actorUserId  String?
  actionType   ActionType
  targetType   String
  targetId     String?
  beforeJson   Json?
  afterJson    Json?
  metadataJson Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  // Relations
  actor User? @relation("ActionLogActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([actionType])
  @@index([createdAt])
}
