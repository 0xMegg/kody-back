# Database
DATABASE_URL="postgresql://user:password@localhost:5432/kody_oms?schema=public"

# Server
PORT=4000
CORS_ORIGIN="http://localhost:3000"
APP_ORIGIN="http://localhost:3000"

# Auth
AUTH_JWT_SECRET="change-me-in-production"

# Invite email / SMTP
# Local dev default: Mailpit at http://localhost:8025, SMTP on 1025.
SMTP_HOST="127.0.0.1"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
EMAIL_FROM="KODY Dev <no-reply@dev.haink.co>"

# Demo/prod SMTP account example. Do not commit real credentials.
# For Gmail/Google Workspace use an App Password, not the account password.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_USER="your-account@example.com"
# SMTP_PASSWORD="app-password-or-provider-secret"
# EMAIL_FROM="KODY <your-account@example.com>"
# Later production target: EMAIL_FROM="KODY <no-reply@haink.co>"
